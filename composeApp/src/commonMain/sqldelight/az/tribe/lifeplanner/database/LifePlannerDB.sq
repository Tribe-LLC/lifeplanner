-- Updated GoalEntity table with new fields
CREATE TABLE GoalEntity (
    id TEXT NOT NULL PRIMARY KEY,
    category TEXT NOT NULL,
    title TEXT NOT NULL,
    description TEXT NOT NULL,
    status TEXT NOT NULL,
    timeline TEXT NOT NULL,
    dueDate TEXT NOT NULL,
    progress INTEGER NOT NULL DEFAULT 0,
    notes TEXT NOT NULL DEFAULT '',
    createdAt TEXT NOT NULL DEFAULT '2025-01-01T00:00:00',
    completionRate REAL NOT NULL DEFAULT 0.0,
    isArchived INTEGER NOT NULL DEFAULT 0,
    aiReasoning TEXT,
    sync_updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    sync_version INTEGER NOT NULL DEFAULT 0,
    last_synced_at TEXT
);

selectAll:
SELECT * FROM GoalEntity WHERE is_deleted = 0 AND id != 'getting_started_goal';

selectGoalById:
SELECT * FROM GoalEntity WHERE id = ?;

-- Updated insert query with conflict resolution
insertGoal:
INSERT OR REPLACE INTO GoalEntity(id, category, title, description, status, timeline, dueDate, progress, notes, createdAt, completionRate, isArchived, aiReasoning, sync_updated_at, is_deleted, sync_version, last_synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

selectGoalsByTimeline:
SELECT * FROM GoalEntity
WHERE timeline = ? AND isArchived = 0 AND is_deleted = 0;

selectGoalsByCategory:
SELECT * FROM GoalEntity
WHERE category = ? AND isArchived = 0 AND is_deleted = 0;

deleteGoalById:
DELETE FROM GoalEntity
WHERE id = ?;

-- Updated update query
updateGoal:
UPDATE GoalEntity
SET
  category = ?,
  title = ?,
  description = ?,
  status = ?,
  timeline = ?,
  dueDate = ?,
  progress = ?,
  notes = ?,
  createdAt = ?,
  completionRate = ?,
  isArchived = ?,
  aiReasoning = ?,
  sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

updateGoalProgress:
UPDATE GoalEntity
SET progress = ?, completionRate = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

updateGoalNotes:
UPDATE GoalEntity
SET notes = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

archiveGoal:
UPDATE GoalEntity
SET isArchived = 1, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

unarchiveGoal:
UPDATE GoalEntity
SET isArchived = 0, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

deleteAllGoals:
DELETE FROM GoalEntity;

searchGoalsByTitle:
SELECT * FROM GoalEntity
WHERE title LIKE '%' || ? || '%' AND isArchived = 0 AND is_deleted = 0;

searchGoalsByDescription:
SELECT * FROM GoalEntity
WHERE description LIKE '%' || ? || '%' AND isArchived = 0 AND is_deleted = 0;

searchGoals:
SELECT * FROM GoalEntity
WHERE (title LIKE '%' || ? || '%' OR description LIKE '%' || ? || '%') AND isArchived = 0 AND is_deleted = 0;

getActiveGoals:
SELECT * FROM GoalEntity
WHERE status != 'COMPLETED' AND isArchived = 0 AND is_deleted = 0 AND id != 'getting_started_goal';

getCompletedGoals:
SELECT * FROM GoalEntity
WHERE status = 'COMPLETED' AND isArchived = 0 AND is_deleted = 0;

getUpcomingDeadlines:
SELECT * FROM GoalEntity
WHERE dueDate >= ? AND dueDate <= ? AND status != 'COMPLETED' AND isArchived = 0 AND is_deleted = 0
ORDER BY dueDate ASC;

getGoalCountByCategory:
SELECT category, COUNT(*)
FROM GoalEntity
WHERE isArchived = 0 AND is_deleted = 0
GROUP BY category;

getGoalCountByTimeline:
SELECT timeline, COUNT(*)
FROM GoalEntity
WHERE isArchived = 0 AND is_deleted = 0
GROUP BY timeline;

getGoalCountByStatus:
SELECT status, COUNT(*)
FROM GoalEntity
WHERE isArchived = 0 AND is_deleted = 0
GROUP BY status;

getAverageProgressByCategory:
SELECT category, AVG(completionRate)
FROM GoalEntity
WHERE isArchived = 0 AND is_deleted = 0
GROUP BY category;

getTotalGoalCount:
SELECT COUNT(*) FROM GoalEntity WHERE isArchived = 0 AND is_deleted = 0 AND id != 'getting_started_goal';

getActiveGoalCount:
SELECT COUNT(*) FROM GoalEntity WHERE status != 'COMPLETED' AND isArchived = 0 AND is_deleted = 0 AND id != 'getting_started_goal';

getCompletedGoalCount:
SELECT COUNT(*) FROM GoalEntity WHERE status = 'COMPLETED' AND isArchived = 0 AND is_deleted = 0 AND id != 'getting_started_goal';

getOverallCompletionRate:
SELECT
    CAST(COUNT(CASE WHEN status = 'COMPLETED' THEN 1 END) AS REAL) / COUNT(*) * 100
FROM GoalEntity
WHERE isArchived = 0 AND is_deleted = 0 AND id != 'getting_started_goal';

-- Milestone table (already exists in your schema)
CREATE TABLE IF NOT EXISTS MilestoneEntity (
    id TEXT PRIMARY KEY NOT NULL,
    goalId TEXT NOT NULL,
    title TEXT NOT NULL,
    isCompleted INTEGER NOT NULL DEFAULT 0,
    dueDate TEXT,
    createdAt TEXT NOT NULL,
    sync_updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    sync_version INTEGER NOT NULL DEFAULT 0,
    last_synced_at TEXT,
    FOREIGN KEY (goalId) REFERENCES GoalEntity(id) ON DELETE CASCADE
);

-- Milestone queries
insertMilestone:
INSERT OR REPLACE INTO MilestoneEntity(id, goalId, title, isCompleted, dueDate, createdAt, sync_updated_at, is_deleted, sync_version, last_synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getMilestonesByGoalId:
SELECT * FROM MilestoneEntity
WHERE goalId = ? AND is_deleted = 0
ORDER BY createdAt ASC;

-- Batch fetch all active milestones (eliminates N+1 when loading goals)
getAllActiveMilestones:
SELECT * FROM MilestoneEntity
WHERE is_deleted = 0
ORDER BY goalId, createdAt ASC;

updateMilestone:
UPDATE MilestoneEntity
SET title = ?, isCompleted = ?, dueDate = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

getGoalIdForMilestone:
SELECT goalId FROM MilestoneEntity WHERE id = ?;

deleteMilestone:
DELETE FROM MilestoneEntity
WHERE id = ?;

toggleMilestoneCompletion:
UPDATE MilestoneEntity
SET isCompleted = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

-- Existing tables remain the same
CREATE TABLE GoalHistoryEntity (
    id TEXT NOT NULL PRIMARY KEY,
    goalId TEXT NOT NULL,
    field TEXT NOT NULL,
    oldValue TEXT,
    newValue TEXT,
    changedAt TEXT NOT NULL,
    sync_updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    sync_version INTEGER NOT NULL DEFAULT 0,
    last_synced_at TEXT
);

insertGoalHistory:
INSERT OR REPLACE INTO GoalHistoryEntity(id, goalId, field, oldValue, newValue, changedAt, sync_updated_at, is_deleted, sync_version, last_synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getGoalHistory:
SELECT * FROM GoalHistoryEntity WHERE goalId = ? AND is_deleted = 0 ORDER BY changedAt DESC;

CREATE TABLE UserProgressEntity (
    id INTEGER PRIMARY KEY DEFAULT 1,
    currentStreak INTEGER NOT NULL DEFAULT 0,
    lastCheckInDate TEXT,
    totalXp INTEGER NOT NULL DEFAULT 0,
    currentLevel INTEGER NOT NULL DEFAULT 1,
    goalsCompleted INTEGER NOT NULL DEFAULT 0,
    habitsCompleted INTEGER NOT NULL DEFAULT 0,
    journalEntriesCount INTEGER NOT NULL DEFAULT 0,
    longestStreak INTEGER NOT NULL DEFAULT 0,
    sync_updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    sync_version INTEGER NOT NULL DEFAULT 0,
    last_synced_at TEXT
);

getUserProgress:
SELECT * FROM UserProgressEntity LIMIT 1;

insertUserProgress:
INSERT OR REPLACE INTO UserProgressEntity(id, currentStreak, lastCheckInDate, totalXp, currentLevel, goalsCompleted, habitsCompleted, journalEntriesCount, longestStreak, sync_updated_at, is_deleted, sync_version, last_synced_at)
VALUES (1, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

updateUserStreak:
UPDATE UserProgressEntity
SET currentStreak = ?, lastCheckInDate = ?, longestStreak = MAX(longestStreak, ?), sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = 1;

updateUserXp:
UPDATE UserProgressEntity
SET totalXp = ?, currentLevel = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = 1;

addXp:
UPDATE UserProgressEntity
SET totalXp = totalXp + ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = 1;

incrementGoalsCompleted:
UPDATE UserProgressEntity
SET goalsCompleted = goalsCompleted + 1, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = 1;

incrementHabitsCompleted:
UPDATE UserProgressEntity
SET habitsCompleted = habitsCompleted + 1, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = 1;

decrementHabitsCompleted:
UPDATE UserProgressEntity
SET habitsCompleted = CASE WHEN habitsCompleted > 0 THEN habitsCompleted - 1 ELSE 0 END, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = 1;

incrementJournalEntries:
UPDATE UserProgressEntity
SET journalEntriesCount = journalEntriesCount + 1, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = 1;

countActiveGoalsByCategory:
SELECT COUNT(*)
FROM GoalEntity
WHERE category = ? AND timeline = ? AND status != 'COMPLETED' AND isArchived = 0 AND is_deleted = 0;

-- User table for storing user profile and onboarding data
CREATE TABLE IF NOT EXISTS UserEntity (
    id TEXT PRIMARY KEY NOT NULL,
    firebaseUid TEXT UNIQUE,
    email TEXT,
    displayName TEXT,
    isGuest INTEGER NOT NULL DEFAULT 0,
    selectedSymbol TEXT,
    priorities TEXT,
    ageRange TEXT,
    profession TEXT,
    relationshipStatus TEXT,
    mindset TEXT,
    hasCompletedOnboarding INTEGER NOT NULL DEFAULT 0,
    createdAt TEXT NOT NULL,
    lastSyncedAt TEXT,
    sync_updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    sync_version INTEGER NOT NULL DEFAULT 0
);

-- User queries
insertUser:
INSERT OR REPLACE INTO UserEntity(id, firebaseUid, email, displayName, isGuest, selectedSymbol, priorities, ageRange, profession, relationshipStatus, mindset, hasCompletedOnboarding, createdAt, lastSyncedAt, sync_updated_at, is_deleted, sync_version)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getCurrentUser:
SELECT * FROM UserEntity WHERE is_deleted = 0 ORDER BY createdAt DESC LIMIT 1;

getUserByFirebaseUid:
SELECT * FROM UserEntity WHERE firebaseUid = ? AND is_deleted = 0 LIMIT 1;

deleteAllUsers:
DELETE FROM UserEntity;

updateUser:
UPDATE UserEntity
SET firebaseUid = ?, email = ?, displayName = ?, isGuest = ?, selectedSymbol = ?, priorities = ?, ageRange = ?, profession = ?, relationshipStatus = ?, mindset = ?, hasCompletedOnboarding = ?, lastSyncedAt = ?, sync_updated_at = ?, is_deleted = ?, sync_version = ?
WHERE id = ?;

updateOnboardingData:
UPDATE UserEntity
SET selectedSymbol = ?, priorities = ?, ageRange = ?, profession = ?, relationshipStatus = ?, mindset = ?, hasCompletedOnboarding = 1, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

markOnboardingComplete:
UPDATE UserEntity
SET hasCompletedOnboarding = 1, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

deleteUser:
DELETE FROM UserEntity WHERE id = ?;

-- Indexes for better performance (already in your schema)
CREATE INDEX IF NOT EXISTS idx_goals_title ON GoalEntity(title);
CREATE INDEX IF NOT EXISTS idx_goals_status ON GoalEntity(status);
CREATE INDEX IF NOT EXISTS idx_goals_category ON GoalEntity(category);
CREATE INDEX IF NOT EXISTS idx_goals_timeline ON GoalEntity(timeline);
CREATE INDEX IF NOT EXISTS idx_goals_duedate ON GoalEntity(dueDate);
CREATE INDEX IF NOT EXISTS idx_goals_archived ON GoalEntity(isArchived);
CREATE INDEX IF NOT EXISTS idx_milestones_goalid ON MilestoneEntity(goalId);
CREATE INDEX IF NOT EXISTS idx_user_firebase_uid ON UserEntity(firebaseUid);

-- Habit Tracking Tables
CREATE TABLE IF NOT EXISTS HabitEntity (
    id TEXT PRIMARY KEY NOT NULL,
    title TEXT NOT NULL,
    description TEXT NOT NULL DEFAULT '',
    category TEXT NOT NULL,
    frequency TEXT NOT NULL DEFAULT 'DAILY',
    targetCount INTEGER NOT NULL DEFAULT 1,
    currentStreak INTEGER NOT NULL DEFAULT 0,
    longestStreak INTEGER NOT NULL DEFAULT 0,
    totalCompletions INTEGER NOT NULL DEFAULT 0,
    lastCompletedDate TEXT,
    linkedGoalId TEXT,
    correlationScore REAL NOT NULL DEFAULT 0.0,
    isActive INTEGER NOT NULL DEFAULT 1,
    createdAt TEXT NOT NULL,
    reminderTime TEXT,
    sync_updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    sync_version INTEGER NOT NULL DEFAULT 0,
    last_synced_at TEXT,
    FOREIGN KEY (linkedGoalId) REFERENCES GoalEntity(id) ON DELETE SET NULL
);

CREATE TABLE IF NOT EXISTS HabitCheckInEntity (
    id TEXT PRIMARY KEY NOT NULL,
    habitId TEXT NOT NULL,
    date TEXT NOT NULL,
    completed INTEGER NOT NULL DEFAULT 1,
    notes TEXT NOT NULL DEFAULT '',
    sync_updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    sync_version INTEGER NOT NULL DEFAULT 0,
    last_synced_at TEXT,
    FOREIGN KEY (habitId) REFERENCES HabitEntity(id) ON DELETE CASCADE
);

-- Habit queries
insertHabit:
INSERT OR REPLACE INTO HabitEntity(id, title, description, category, frequency, targetCount, currentStreak, longestStreak, totalCompletions, lastCompletedDate, linkedGoalId, correlationScore, isActive, createdAt, reminderTime, sync_updated_at, is_deleted, sync_version, last_synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getAllHabits:
SELECT * FROM HabitEntity WHERE isActive = 1 AND is_deleted = 0 ORDER BY createdAt DESC;

getHabitById:
SELECT * FROM HabitEntity WHERE id = ? AND is_deleted = 0;

getHabitsByCategory:
SELECT * FROM HabitEntity WHERE category = ? AND isActive = 1 AND is_deleted = 0;

getHabitsByGoalId:
SELECT * FROM HabitEntity WHERE linkedGoalId = ? AND isActive = 1 AND is_deleted = 0;

updateHabit:
UPDATE HabitEntity
SET title = ?, description = ?, category = ?, frequency = ?, targetCount = ?, linkedGoalId = ?, reminderTime = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

updateHabitStreak:
UPDATE HabitEntity
SET currentStreak = ?, longestStreak = ?, totalCompletions = ?, lastCompletedDate = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

updateHabitCorrelation:
UPDATE HabitEntity
SET correlationScore = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

deactivateHabit:
UPDATE HabitEntity SET isActive = 0, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now') WHERE id = ?;

deleteHabit:
DELETE FROM HabitEntity WHERE id = ?;

-- Habit check-in queries
insertHabitCheckIn:
INSERT OR REPLACE INTO HabitCheckInEntity(id, habitId, date, completed, notes, sync_updated_at, is_deleted, sync_version, last_synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

insertHabitCheckInOrIgnore:
INSERT OR IGNORE INTO HabitCheckInEntity(id, habitId, date, completed, notes, sync_updated_at, is_deleted, sync_version, last_synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

getCheckInsByHabitId:
SELECT * FROM HabitCheckInEntity WHERE habitId = ? AND is_deleted = 0 ORDER BY date DESC;

getCheckInsByDate:
SELECT * FROM HabitCheckInEntity WHERE date = ? AND is_deleted = 0;

getCheckInByHabitAndDate:
SELECT * FROM HabitCheckInEntity WHERE habitId = ? AND date = ? AND is_deleted = 0 LIMIT 1;

-- Delete duplicate check-ins (keeps the first one)
deleteDuplicateCheckIns:
DELETE FROM HabitCheckInEntity
WHERE id NOT IN (
    SELECT MIN(id) FROM HabitCheckInEntity GROUP BY habitId, date
);

deleteCheckIn:
DELETE FROM HabitCheckInEntity WHERE id = ?;

getCheckInsInRange:
SELECT * FROM HabitCheckInEntity WHERE habitId = ? AND date >= ? AND date <= ? AND is_deleted = 0 ORDER BY date ASC;

-- Get completed check-in dates for a habit in descending order (for streak calculation)
getCompletedCheckInDatesDesc:
SELECT date FROM HabitCheckInEntity
WHERE habitId = ? AND completed = 1 AND is_deleted = 0
ORDER BY date DESC;

getTodayCheckIns:
SELECT h.id, h.title, h.description, h.category, h.frequency, h.targetCount,
       h.currentStreak, h.longestStreak, h.totalCompletions, h.lastCompletedDate,
       h.linkedGoalId, h.correlationScore, h.isActive, h.createdAt, h.reminderTime,
       c.completed
FROM HabitEntity h
LEFT JOIN HabitCheckInEntity c ON h.id = c.habitId AND c.date = ?
WHERE h.isActive = 1 AND h.is_deleted = 0;

getHabitCompletionStats:
SELECT habitId, COUNT(*)
FROM HabitCheckInEntity
WHERE completed = 1 AND date >= ? AND date <= ?
GROUP BY habitId;

-- Indexes for habits
CREATE INDEX IF NOT EXISTS idx_habits_category ON HabitEntity(category);
CREATE INDEX IF NOT EXISTS idx_habits_linked_goal ON HabitEntity(linkedGoalId);
CREATE INDEX IF NOT EXISTS idx_habits_active ON HabitEntity(isActive);
CREATE UNIQUE INDEX IF NOT EXISTS idx_checkins_habit_date ON HabitCheckInEntity(habitId, date);
CREATE INDEX IF NOT EXISTS idx_checkins_habit ON HabitCheckInEntity(habitId);
CREATE INDEX IF NOT EXISTS idx_checkins_date ON HabitCheckInEntity(date);

-- Journal Entry Table
CREATE TABLE IF NOT EXISTS JournalEntryEntity (
    id TEXT PRIMARY KEY NOT NULL,
    title TEXT NOT NULL,
    content TEXT NOT NULL,
    mood TEXT NOT NULL DEFAULT 'NEUTRAL',
    linkedGoalId TEXT,
    linkedHabitId TEXT,
    promptUsed TEXT,
    tags TEXT NOT NULL DEFAULT '',
    date TEXT NOT NULL,
    createdAt TEXT NOT NULL,
    updatedAt TEXT,
    sync_updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    sync_version INTEGER NOT NULL DEFAULT 0,
    last_synced_at TEXT,
    FOREIGN KEY (linkedGoalId) REFERENCES GoalEntity(id) ON DELETE SET NULL,
    FOREIGN KEY (linkedHabitId) REFERENCES HabitEntity(id) ON DELETE SET NULL
);

-- Journal queries
insertJournalEntry:
INSERT OR REPLACE INTO JournalEntryEntity(id, title, content, mood, linkedGoalId, linkedHabitId, promptUsed, tags, date, createdAt, updatedAt, sync_updated_at, is_deleted, sync_version, last_synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getAllJournalEntries:
SELECT * FROM JournalEntryEntity WHERE is_deleted = 0 ORDER BY date DESC, createdAt DESC;

getJournalEntryById:
SELECT * FROM JournalEntryEntity WHERE id = ? AND is_deleted = 0;

getJournalEntriesByDate:
SELECT * FROM JournalEntryEntity WHERE date = ? AND is_deleted = 0 ORDER BY createdAt DESC;

getJournalEntriesByGoalId:
SELECT * FROM JournalEntryEntity WHERE linkedGoalId = ? AND is_deleted = 0 ORDER BY date DESC;

getJournalEntriesByMood:
SELECT * FROM JournalEntryEntity WHERE mood = ? AND is_deleted = 0 ORDER BY date DESC;

getJournalEntriesInRange:
SELECT * FROM JournalEntryEntity WHERE date >= ? AND date <= ? AND is_deleted = 0 ORDER BY date DESC;

updateJournalEntry:
UPDATE JournalEntryEntity
SET title = ?, content = ?, mood = ?, linkedGoalId = ?, linkedHabitId = ?, promptUsed = ?, tags = ?, updatedAt = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

getJournalEntriesByHabitId:
SELECT * FROM JournalEntryEntity WHERE linkedHabitId = ? AND is_deleted = 0 ORDER BY date DESC;

deleteJournalEntry:
DELETE FROM JournalEntryEntity WHERE id = ?;

searchJournalEntries:
SELECT * FROM JournalEntryEntity
WHERE (title LIKE '%' || ? || '%' OR content LIKE '%' || ? || '%') AND is_deleted = 0
ORDER BY date DESC;

getRecentJournalEntries:
SELECT * FROM JournalEntryEntity WHERE is_deleted = 0 ORDER BY date DESC, createdAt DESC LIMIT ?;

getMoodCountInRange:
SELECT mood, COUNT(*)
FROM JournalEntryEntity
WHERE date >= ? AND date <= ? AND is_deleted = 0
GROUP BY mood;

-- Indexes for journal
CREATE INDEX IF NOT EXISTS idx_journal_date ON JournalEntryEntity(date);
CREATE INDEX IF NOT EXISTS idx_journal_mood ON JournalEntryEntity(mood);
CREATE INDEX IF NOT EXISTS idx_journal_goal ON JournalEntryEntity(linkedGoalId);
CREATE INDEX IF NOT EXISTS idx_journal_habit ON JournalEntryEntity(linkedHabitId);

-- Badge Table for earned achievements
CREATE TABLE IF NOT EXISTS BadgeEntity (
    id TEXT PRIMARY KEY NOT NULL,
    badgeType TEXT NOT NULL,
    earnedAt TEXT NOT NULL,
    isNew INTEGER NOT NULL DEFAULT 1,
    sync_updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    sync_version INTEGER NOT NULL DEFAULT 0,
    last_synced_at TEXT
);

-- Challenge Table for active/completed challenges
CREATE TABLE IF NOT EXISTS ChallengeEntity (
    id TEXT PRIMARY KEY NOT NULL,
    challengeType TEXT NOT NULL,
    startDate TEXT NOT NULL,
    endDate TEXT NOT NULL,
    currentProgress INTEGER NOT NULL DEFAULT 0,
    targetProgress INTEGER NOT NULL,
    isCompleted INTEGER NOT NULL DEFAULT 0,
    completedAt TEXT,
    xpEarned INTEGER NOT NULL DEFAULT 0,
    sync_updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    sync_version INTEGER NOT NULL DEFAULT 0,
    last_synced_at TEXT
);

-- Badge queries
insertBadge:
INSERT OR REPLACE INTO BadgeEntity(id, badgeType, earnedAt, isNew, sync_updated_at, is_deleted, sync_version, last_synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?);

getAllBadges:
SELECT * FROM BadgeEntity WHERE is_deleted = 0 ORDER BY earnedAt DESC;

getBadgeByType:
SELECT * FROM BadgeEntity WHERE badgeType = ? AND is_deleted = 0;

hasBadge:
SELECT COUNT(*) FROM BadgeEntity WHERE badgeType = ? AND is_deleted = 0;

markBadgeAsSeen:
UPDATE BadgeEntity SET isNew = 0, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now') WHERE id = ?;

markAllBadgesAsSeen:
UPDATE BadgeEntity SET isNew = 0, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now');

getNewBadges:
SELECT * FROM BadgeEntity WHERE isNew = 1 AND is_deleted = 0;

getBadgeCount:
SELECT COUNT(*) FROM BadgeEntity WHERE is_deleted = 0;

-- Challenge queries
insertChallenge:
INSERT OR REPLACE INTO ChallengeEntity(id, challengeType, startDate, endDate, currentProgress, targetProgress, isCompleted, completedAt, xpEarned, sync_updated_at, is_deleted, sync_version, last_synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getAllChallenges:
SELECT * FROM ChallengeEntity WHERE is_deleted = 0 ORDER BY startDate DESC;

getActiveChallenges:
SELECT * FROM ChallengeEntity WHERE isCompleted = 0 AND endDate >= ? AND is_deleted = 0 ORDER BY endDate ASC;

getCompletedChallenges:
SELECT * FROM ChallengeEntity WHERE isCompleted = 1 AND is_deleted = 0 ORDER BY completedAt DESC;

getChallengeById:
SELECT * FROM ChallengeEntity WHERE id = ? AND is_deleted = 0;

getChallengeByType:
SELECT * FROM ChallengeEntity WHERE challengeType = ? AND isCompleted = 0 AND is_deleted = 0;

updateChallengeProgress:
UPDATE ChallengeEntity
SET currentProgress = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

completeChallenge:
UPDATE ChallengeEntity
SET isCompleted = 1, completedAt = ?, xpEarned = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

deleteChallenge:
DELETE FROM ChallengeEntity WHERE id = ?;

deleteExpiredChallenges:
DELETE FROM ChallengeEntity WHERE isCompleted = 0 AND endDate < ?;

-- Indexes for gamification
CREATE INDEX IF NOT EXISTS idx_badge_type ON BadgeEntity(badgeType);
CREATE INDEX IF NOT EXISTS idx_badge_new ON BadgeEntity(isNew);
CREATE INDEX IF NOT EXISTS idx_challenge_type ON ChallengeEntity(challengeType);
CREATE INDEX IF NOT EXISTS idx_challenge_completed ON ChallengeEntity(isCompleted);
CREATE INDEX IF NOT EXISTS idx_challenge_end_date ON ChallengeEntity(endDate);

-- Goal Dependency Table for tracking relationships between goals
CREATE TABLE IF NOT EXISTS GoalDependencyEntity (
    id TEXT PRIMARY KEY NOT NULL,
    sourceGoalId TEXT NOT NULL,
    targetGoalId TEXT NOT NULL,
    dependencyType TEXT NOT NULL,
    createdAt TEXT NOT NULL,
    sync_updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    sync_version INTEGER NOT NULL DEFAULT 0,
    last_synced_at TEXT,
    FOREIGN KEY (sourceGoalId) REFERENCES GoalEntity(id) ON DELETE CASCADE,
    FOREIGN KEY (targetGoalId) REFERENCES GoalEntity(id) ON DELETE CASCADE
);

-- Goal Dependency queries
insertGoalDependency:
INSERT OR REPLACE INTO GoalDependencyEntity(id, sourceGoalId, targetGoalId, dependencyType, createdAt, sync_updated_at, is_deleted, sync_version, last_synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

getAllDependencies:
SELECT * FROM GoalDependencyEntity WHERE is_deleted = 0;

getDependenciesBySourceGoal:
SELECT * FROM GoalDependencyEntity WHERE sourceGoalId = ? AND is_deleted = 0;

getDependenciesByTargetGoal:
SELECT * FROM GoalDependencyEntity WHERE targetGoalId = ? AND is_deleted = 0;

getDependenciesForGoal:
SELECT * FROM GoalDependencyEntity WHERE (sourceGoalId = ? OR targetGoalId = ?) AND is_deleted = 0;

getDependencyById:
SELECT * FROM GoalDependencyEntity WHERE id = ? AND is_deleted = 0;

getDependencyBetweenGoals:
SELECT * FROM GoalDependencyEntity
WHERE ((sourceGoalId = ? AND targetGoalId = ?) OR (sourceGoalId = ? AND targetGoalId = ?)) AND is_deleted = 0;

deleteDependency:
DELETE FROM GoalDependencyEntity WHERE id = ?;

deleteDependenciesByGoal:
DELETE FROM GoalDependencyEntity WHERE sourceGoalId = ? OR targetGoalId = ?;

getDependencyCount:
SELECT COUNT(*) FROM GoalDependencyEntity;

getBlockingGoals:
SELECT DISTINCT g.*
FROM GoalEntity g
INNER JOIN GoalDependencyEntity d ON g.id = d.targetGoalId
WHERE d.sourceGoalId = ? AND d.dependencyType = 'BLOCKED_BY';

getBlockedGoals:
SELECT DISTINCT g.*
FROM GoalEntity g
INNER JOIN GoalDependencyEntity d ON g.id = d.targetGoalId
WHERE d.sourceGoalId = ? AND d.dependencyType = 'BLOCKS';

getChildGoals:
SELECT DISTINCT g.*
FROM GoalEntity g
INNER JOIN GoalDependencyEntity d ON g.id = d.targetGoalId
WHERE d.sourceGoalId = ? AND d.dependencyType = 'PARENT_OF';

getParentGoals:
SELECT DISTINCT g.*
FROM GoalEntity g
INNER JOIN GoalDependencyEntity d ON g.id = d.targetGoalId
WHERE d.sourceGoalId = ? AND d.dependencyType = 'CHILD_OF';

getRelatedGoals:
SELECT DISTINCT g.*
FROM GoalEntity g
INNER JOIN GoalDependencyEntity d ON g.id = d.targetGoalId
WHERE d.sourceGoalId = ? AND (d.dependencyType = 'RELATED' OR d.dependencyType = 'SUPPORTS');

-- Indexes for goal dependencies
CREATE INDEX IF NOT EXISTS idx_dependency_source ON GoalDependencyEntity(sourceGoalId);
CREATE INDEX IF NOT EXISTS idx_dependency_target ON GoalDependencyEntity(targetGoalId);
CREATE INDEX IF NOT EXISTS idx_dependency_type ON GoalDependencyEntity(dependencyType);

-- AI Coach Chat Tables
CREATE TABLE IF NOT EXISTS ChatSessionEntity (
    id TEXT PRIMARY KEY NOT NULL,
    title TEXT NOT NULL,
    createdAt TEXT NOT NULL,
    lastMessageAt TEXT NOT NULL,
    summary TEXT,
    coachId TEXT NOT NULL DEFAULT 'luna_general',
    sync_updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    sync_version INTEGER NOT NULL DEFAULT 0,
    last_synced_at TEXT
);

CREATE TABLE IF NOT EXISTS ChatMessageEntity (
    id TEXT PRIMARY KEY NOT NULL,
    sessionId TEXT NOT NULL,
    content TEXT NOT NULL,
    role TEXT NOT NULL,
    timestamp TEXT NOT NULL,
    relatedGoalId TEXT,
    metadata TEXT,
    sync_updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    sync_version INTEGER NOT NULL DEFAULT 0,
    last_synced_at TEXT,
    FOREIGN KEY (sessionId) REFERENCES ChatSessionEntity(id) ON DELETE CASCADE
);

-- Chat Session queries
insertChatSession:
INSERT OR REPLACE INTO ChatSessionEntity(id, title, createdAt, lastMessageAt, summary, coachId, sync_updated_at, is_deleted, sync_version, last_synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getAllChatSessions:
SELECT * FROM ChatSessionEntity WHERE is_deleted = 0 ORDER BY lastMessageAt DESC;

getChatSessionById:
SELECT * FROM ChatSessionEntity WHERE id = ? AND is_deleted = 0;

getChatSessionByCoachId:
SELECT * FROM ChatSessionEntity WHERE coachId = ? AND is_deleted = 0 LIMIT 1;

updateChatSessionLastMessage:
UPDATE ChatSessionEntity
SET lastMessageAt = ?, title = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

updateChatSessionSummary:
UPDATE ChatSessionEntity
SET summary = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

deleteChatSession:
DELETE FROM ChatSessionEntity WHERE id = ?;

deleteOldChatSessions:
DELETE FROM ChatSessionEntity WHERE lastMessageAt < ?;

getChatSessionCount:
SELECT COUNT(*) FROM ChatSessionEntity WHERE is_deleted = 0;

-- Chat Message queries
insertChatMessage:
INSERT OR REPLACE INTO ChatMessageEntity(id, sessionId, content, role, timestamp, relatedGoalId, metadata, sync_updated_at, is_deleted, sync_version, last_synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

updateChatMessageMetadata:
UPDATE ChatMessageEntity SET metadata = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now') WHERE id = ?;

getMessagesBySessionId:
SELECT * FROM ChatMessageEntity WHERE sessionId = ? AND is_deleted = 0 ORDER BY timestamp ASC;

getRecentMessages:
SELECT * FROM ChatMessageEntity WHERE sessionId = ? AND is_deleted = 0 ORDER BY timestamp DESC LIMIT ?;

getMessageById:
SELECT * FROM ChatMessageEntity WHERE id = ? AND is_deleted = 0;

deleteMessage:
DELETE FROM ChatMessageEntity WHERE id = ?;

deleteMessagesBySession:
DELETE FROM ChatMessageEntity WHERE sessionId = ?;

getMessageCountBySession:
SELECT COUNT(*) FROM ChatMessageEntity WHERE sessionId = ? AND is_deleted = 0;

getLastMessageBySession:
SELECT * FROM ChatMessageEntity WHERE sessionId = ? AND is_deleted = 0 ORDER BY timestamp DESC LIMIT 1;

-- Indexes for chat
CREATE INDEX IF NOT EXISTS idx_chat_session_last_message ON ChatSessionEntity(lastMessageAt);
CREATE INDEX IF NOT EXISTS idx_chat_message_session ON ChatMessageEntity(sessionId);
CREATE INDEX IF NOT EXISTS idx_chat_message_timestamp ON ChatMessageEntity(timestamp);

-- AI Review Tables
CREATE TABLE IF NOT EXISTS ReviewReportEntity (
    id TEXT PRIMARY KEY NOT NULL,
    type TEXT NOT NULL,
    periodStart TEXT NOT NULL,
    periodEnd TEXT NOT NULL,
    generatedAt TEXT NOT NULL,
    summary TEXT NOT NULL,
    highlightsJson TEXT NOT NULL,
    insightsJson TEXT NOT NULL,
    recommendationsJson TEXT NOT NULL,
    statsJson TEXT NOT NULL,
    feedbackRating TEXT,
    feedbackComment TEXT,
    feedbackAt TEXT,
    isRead INTEGER NOT NULL DEFAULT 0,
    sync_updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    sync_version INTEGER NOT NULL DEFAULT 0,
    last_synced_at TEXT
);

-- Review queries
insertReview:
INSERT OR REPLACE INTO ReviewReportEntity(
    id, type, periodStart, periodEnd, generatedAt, summary,
    highlightsJson, insightsJson, recommendationsJson, statsJson,
    feedbackRating, feedbackComment, feedbackAt, isRead,
    sync_updated_at, is_deleted, sync_version, last_synced_at
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getAllReviews:
SELECT * FROM ReviewReportEntity WHERE is_deleted = 0 ORDER BY generatedAt DESC;

getReviewById:
SELECT * FROM ReviewReportEntity WHERE id = ? AND is_deleted = 0;

getReviewsByType:
SELECT * FROM ReviewReportEntity WHERE type = ? AND is_deleted = 0 ORDER BY generatedAt DESC;

getLatestReviewByType:
SELECT * FROM ReviewReportEntity WHERE type = ? AND is_deleted = 0 ORDER BY generatedAt DESC LIMIT 1;

getUnreadReviews:
SELECT * FROM ReviewReportEntity WHERE isRead = 0 AND is_deleted = 0 ORDER BY generatedAt DESC;

markReviewAsRead:
UPDATE ReviewReportEntity SET isRead = 1, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now') WHERE id = ?;

updateReviewFeedback:
UPDATE ReviewReportEntity
SET feedbackRating = ?, feedbackComment = ?, feedbackAt = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

deleteReview:
DELETE FROM ReviewReportEntity WHERE id = ?;

deleteOldReviews:
DELETE FROM ReviewReportEntity WHERE generatedAt < ?;

getReviewCount:
SELECT COUNT(*) FROM ReviewReportEntity WHERE is_deleted = 0;

getUnreadReviewCount:
SELECT COUNT(*) FROM ReviewReportEntity WHERE isRead = 0 AND is_deleted = 0;

-- Index for reviews
CREATE INDEX IF NOT EXISTS idx_review_type ON ReviewReportEntity(type);
CREATE INDEX IF NOT EXISTS idx_review_generated ON ReviewReportEntity(generatedAt);
CREATE INDEX IF NOT EXISTS idx_review_unread ON ReviewReportEntity(isRead);

-- Smart Reminders Tables
CREATE TABLE IF NOT EXISTS ReminderEntity (
    id TEXT PRIMARY KEY NOT NULL,
    title TEXT NOT NULL,
    message TEXT NOT NULL,
    type TEXT NOT NULL,
    frequency TEXT NOT NULL,
    scheduledTime TEXT NOT NULL,
    scheduledDays TEXT NOT NULL DEFAULT '',
    linkedGoalId TEXT,
    linkedHabitId TEXT,
    isEnabled INTEGER NOT NULL DEFAULT 1,
    isSmartTiming INTEGER NOT NULL DEFAULT 0,
    lastTriggeredAt TEXT,
    snoozedUntil TEXT,
    createdAt TEXT NOT NULL,
    updatedAt TEXT,
    sync_updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    sync_version INTEGER NOT NULL DEFAULT 0,
    last_synced_at TEXT,
    FOREIGN KEY (linkedGoalId) REFERENCES GoalEntity(id) ON DELETE SET NULL,
    FOREIGN KEY (linkedHabitId) REFERENCES HabitEntity(id) ON DELETE SET NULL
);

CREATE TABLE IF NOT EXISTS ReminderSettingsEntity (
    id TEXT PRIMARY KEY NOT NULL DEFAULT 'default',
    isEnabled INTEGER NOT NULL DEFAULT 1,
    quietHoursStart TEXT NOT NULL DEFAULT '22:00',
    quietHoursEnd TEXT NOT NULL DEFAULT '07:00',
    preferredMorningTime TEXT NOT NULL DEFAULT '08:00',
    preferredEveningTime TEXT NOT NULL DEFAULT '20:00',
    smartTimingEnabled INTEGER NOT NULL DEFAULT 1,
    maxRemindersPerDay INTEGER NOT NULL DEFAULT 5,
    weeklyReviewDay TEXT NOT NULL DEFAULT 'SUNDAY',
    weeklyReviewTime TEXT NOT NULL DEFAULT '10:00'
);

CREATE TABLE IF NOT EXISTS UserActivityPatternEntity (
    id TEXT PRIMARY KEY NOT NULL DEFAULT 'default',
    mostActiveHours TEXT NOT NULL DEFAULT '',
    mostActiveDays TEXT NOT NULL DEFAULT '',
    averageResponseTime INTEGER NOT NULL DEFAULT 0,
    bestCheckInTimes TEXT NOT NULL DEFAULT '',
    lastUpdated TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS ScheduledNotificationEntity (
    id TEXT PRIMARY KEY NOT NULL,
    reminderId TEXT NOT NULL,
    title TEXT NOT NULL,
    message TEXT NOT NULL,
    scheduledAt TEXT NOT NULL,
    isDelivered INTEGER NOT NULL DEFAULT 0,
    deliveredAt TEXT,
    isSnoozed INTEGER NOT NULL DEFAULT 0,
    isDismissed INTEGER NOT NULL DEFAULT 0,
    FOREIGN KEY (reminderId) REFERENCES ReminderEntity(id) ON DELETE CASCADE
);

-- Reminder queries
insertReminder:
INSERT OR REPLACE INTO ReminderEntity(
    id, title, message, type, frequency, scheduledTime, scheduledDays,
    linkedGoalId, linkedHabitId, isEnabled, isSmartTiming, lastTriggeredAt,
    snoozedUntil, createdAt, updatedAt,
    sync_updated_at, is_deleted, sync_version, last_synced_at
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getAllReminders:
SELECT * FROM ReminderEntity WHERE is_deleted = 0 ORDER BY createdAt DESC;

getEnabledReminders:
SELECT * FROM ReminderEntity WHERE isEnabled = 1 AND is_deleted = 0 ORDER BY scheduledTime ASC;

getReminderById:
SELECT * FROM ReminderEntity WHERE id = ? AND is_deleted = 0;

getRemindersByGoalId:
SELECT * FROM ReminderEntity WHERE linkedGoalId = ? AND isEnabled = 1 AND is_deleted = 0;

getRemindersByHabitId:
SELECT * FROM ReminderEntity WHERE linkedHabitId = ? AND isEnabled = 1 AND is_deleted = 0;

getRemindersByType:
SELECT * FROM ReminderEntity WHERE type = ? AND isEnabled = 1 AND is_deleted = 0;

updateReminder:
UPDATE ReminderEntity
SET title = ?, message = ?, type = ?, frequency = ?, scheduledTime = ?,
    scheduledDays = ?, linkedGoalId = ?, linkedHabitId = ?, isEnabled = ?,
    isSmartTiming = ?, updatedAt = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

updateReminderLastTriggered:
UPDATE ReminderEntity
SET lastTriggeredAt = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

snoozeReminder:
UPDATE ReminderEntity
SET snoozedUntil = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

enableReminder:
UPDATE ReminderEntity SET isEnabled = 1, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now') WHERE id = ?;

disableReminder:
UPDATE ReminderEntity SET isEnabled = 0, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now') WHERE id = ?;

enableAllReminders:
UPDATE ReminderEntity SET isEnabled = 1, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now');

disableAllReminders:
UPDATE ReminderEntity SET isEnabled = 0, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now');

deleteReminder:
DELETE FROM ReminderEntity WHERE id = ?;

getReminderCount:
SELECT COUNT(*) FROM ReminderEntity WHERE isEnabled = 1 AND is_deleted = 0;

-- Reminder Settings queries
getReminderSettings:
SELECT * FROM ReminderSettingsEntity WHERE id = 'default';

insertReminderSettings:
INSERT OR REPLACE INTO ReminderSettingsEntity(
    id, isEnabled, quietHoursStart, quietHoursEnd, preferredMorningTime,
    preferredEveningTime, smartTimingEnabled, maxRemindersPerDay,
    weeklyReviewDay, weeklyReviewTime
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

updateReminderSettings:
UPDATE ReminderSettingsEntity
SET isEnabled = ?, quietHoursStart = ?, quietHoursEnd = ?, preferredMorningTime = ?,
    preferredEveningTime = ?, smartTimingEnabled = ?, maxRemindersPerDay = ?,
    weeklyReviewDay = ?, weeklyReviewTime = ?
WHERE id = 'default';

-- User Activity Pattern queries
getUserActivityPattern:
SELECT * FROM UserActivityPatternEntity WHERE id = 'default';

insertUserActivityPattern:
INSERT OR REPLACE INTO UserActivityPatternEntity(
    id, mostActiveHours, mostActiveDays, averageResponseTime, bestCheckInTimes, lastUpdated
) VALUES (?, ?, ?, ?, ?, ?);

updateUserActivityPattern:
UPDATE UserActivityPatternEntity
SET mostActiveHours = ?, mostActiveDays = ?, averageResponseTime = ?,
    bestCheckInTimes = ?, lastUpdated = ?
WHERE id = 'default';

-- Scheduled Notification queries
insertScheduledNotification:
INSERT OR REPLACE INTO ScheduledNotificationEntity(
    id, reminderId, title, message, scheduledAt, isDelivered, deliveredAt, isSnoozed, isDismissed
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

getScheduledNotifications:
SELECT * FROM ScheduledNotificationEntity WHERE isDelivered = 0 AND isDismissed = 0 ORDER BY scheduledAt ASC;

getScheduledNotificationById:
SELECT * FROM ScheduledNotificationEntity WHERE id = ?;

getScheduledNotificationsByReminder:
SELECT * FROM ScheduledNotificationEntity WHERE reminderId = ? ORDER BY scheduledAt ASC;

markNotificationDelivered:
UPDATE ScheduledNotificationEntity
SET isDelivered = 1, deliveredAt = ?
WHERE id = ?;

markNotificationSnoozed:
UPDATE ScheduledNotificationEntity
SET isSnoozed = 1
WHERE id = ?;

dismissNotification:
UPDATE ScheduledNotificationEntity
SET isDismissed = 1
WHERE id = ?;

deleteScheduledNotification:
DELETE FROM ScheduledNotificationEntity WHERE id = ?;

deleteScheduledNotificationsByReminder:
DELETE FROM ScheduledNotificationEntity WHERE reminderId = ?;

deleteDeliveredNotifications:
DELETE FROM ScheduledNotificationEntity WHERE isDelivered = 1 AND deliveredAt < ?;

getPendingNotificationCount:
SELECT COUNT(*) FROM ScheduledNotificationEntity WHERE isDelivered = 0 AND isDismissed = 0;

-- Indexes for reminders
CREATE INDEX IF NOT EXISTS idx_reminder_type ON ReminderEntity(type);
CREATE INDEX IF NOT EXISTS idx_reminder_enabled ON ReminderEntity(isEnabled);
CREATE INDEX IF NOT EXISTS idx_reminder_goal ON ReminderEntity(linkedGoalId);
CREATE INDEX IF NOT EXISTS idx_reminder_habit ON ReminderEntity(linkedHabitId);
CREATE INDEX IF NOT EXISTS idx_scheduled_reminder ON ScheduledNotificationEntity(reminderId);
CREATE INDEX IF NOT EXISTS idx_scheduled_time ON ScheduledNotificationEntity(scheduledAt);
CREATE INDEX IF NOT EXISTS idx_scheduled_delivered ON ScheduledNotificationEntity(isDelivered);

-- Custom Coach Tables
CREATE TABLE IF NOT EXISTS CustomCoachEntity (
    id TEXT PRIMARY KEY NOT NULL,
    name TEXT NOT NULL,
    icon TEXT NOT NULL,
    iconBackgroundColor TEXT NOT NULL DEFAULT '#6366F1',
    iconAccentColor TEXT NOT NULL DEFAULT '#818CF8',
    systemPrompt TEXT NOT NULL,
    characteristics TEXT NOT NULL DEFAULT '',
    isFromTemplate INTEGER NOT NULL DEFAULT 0,
    templateId TEXT,
    createdAt TEXT NOT NULL,
    updatedAt TEXT,
    sync_updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    sync_version INTEGER NOT NULL DEFAULT 0,
    last_synced_at TEXT
);

CREATE TABLE IF NOT EXISTS CoachGroupEntity (
    id TEXT PRIMARY KEY NOT NULL,
    name TEXT NOT NULL,
    icon TEXT NOT NULL,
    description TEXT NOT NULL DEFAULT '',
    createdAt TEXT NOT NULL,
    updatedAt TEXT,
    sync_updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    sync_version INTEGER NOT NULL DEFAULT 0,
    last_synced_at TEXT
);

CREATE TABLE IF NOT EXISTS CoachGroupMemberEntity (
    id TEXT PRIMARY KEY NOT NULL,
    groupId TEXT NOT NULL,
    coachType TEXT NOT NULL,
    coachId TEXT NOT NULL,
    displayOrder INTEGER NOT NULL DEFAULT 0,
    sync_updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    sync_version INTEGER NOT NULL DEFAULT 0,
    last_synced_at TEXT,
    FOREIGN KEY (groupId) REFERENCES CoachGroupEntity(id) ON DELETE CASCADE
);

-- Custom Coach queries
insertCustomCoach:
INSERT OR REPLACE INTO CustomCoachEntity(id, name, icon, iconBackgroundColor, iconAccentColor, systemPrompt, characteristics, isFromTemplate, templateId, createdAt, updatedAt, sync_updated_at, is_deleted, sync_version, last_synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getAllCustomCoaches:
SELECT * FROM CustomCoachEntity WHERE is_deleted = 0 ORDER BY createdAt DESC;

getCustomCoachById:
SELECT * FROM CustomCoachEntity WHERE id = ? AND is_deleted = 0;

updateCustomCoach:
UPDATE CustomCoachEntity
SET name = ?, icon = ?, iconBackgroundColor = ?, iconAccentColor = ?, systemPrompt = ?, characteristics = ?, updatedAt = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

deleteCustomCoach:
DELETE FROM CustomCoachEntity WHERE id = ?;

getCustomCoachCount:
SELECT COUNT(*) FROM CustomCoachEntity WHERE is_deleted = 0;

-- Coach Group queries
insertCoachGroup:
INSERT OR REPLACE INTO CoachGroupEntity(id, name, icon, description, createdAt, updatedAt, sync_updated_at, is_deleted, sync_version, last_synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getAllCoachGroups:
SELECT * FROM CoachGroupEntity WHERE is_deleted = 0 ORDER BY createdAt DESC;

getCoachGroupById:
SELECT * FROM CoachGroupEntity WHERE id = ? AND is_deleted = 0;

updateCoachGroup:
UPDATE CoachGroupEntity
SET name = ?, icon = ?, description = ?, updatedAt = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

deleteCoachGroup:
DELETE FROM CoachGroupEntity WHERE id = ?;

getCoachGroupCount:
SELECT COUNT(*) FROM CoachGroupEntity WHERE is_deleted = 0;

-- Coach Group Member queries
insertCoachGroupMember:
INSERT OR REPLACE INTO CoachGroupMemberEntity(id, groupId, coachType, coachId, displayOrder, sync_updated_at, is_deleted, sync_version, last_synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

getCoachGroupMembers:
SELECT * FROM CoachGroupMemberEntity WHERE groupId = ? AND is_deleted = 0 ORDER BY displayOrder ASC;

-- Batch fetch all active coach group members (eliminates N+1 when loading groups)
getAllActiveCoachGroupMembers:
SELECT * FROM CoachGroupMemberEntity
WHERE is_deleted = 0
ORDER BY groupId, displayOrder ASC;

deleteCoachGroupMember:
DELETE FROM CoachGroupMemberEntity WHERE id = ?;

deleteCoachGroupMembersByGroup:
DELETE FROM CoachGroupMemberEntity WHERE groupId = ?;

updateCoachGroupMemberOrder:
UPDATE CoachGroupMemberEntity SET displayOrder = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now') WHERE id = ?;

-- Indexes for custom coaches
CREATE INDEX IF NOT EXISTS idx_custom_coach_template ON CustomCoachEntity(templateId);
CREATE INDEX IF NOT EXISTS idx_coach_group_member_group ON CoachGroupMemberEntity(groupId);
CREATE INDEX IF NOT EXISTS idx_coach_group_member_coach ON CoachGroupMemberEntity(coachId);

-- Focus Session Table for pomodoro-style focus timer
CREATE TABLE IF NOT EXISTS FocusSessionEntity (
    id TEXT PRIMARY KEY NOT NULL,
    goalId TEXT NOT NULL,
    milestoneId TEXT NOT NULL,
    plannedDurationMinutes INTEGER NOT NULL,
    actualDurationSeconds INTEGER NOT NULL DEFAULT 0,
    wasCompleted INTEGER NOT NULL DEFAULT 0,
    xpEarned INTEGER NOT NULL DEFAULT 0,
    startedAt TEXT NOT NULL,
    completedAt TEXT,
    createdAt TEXT NOT NULL,
    mood TEXT,
    ambientSound TEXT,
    focusTheme TEXT,
    sync_updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    sync_version INTEGER NOT NULL DEFAULT 0,
    last_synced_at TEXT,
    FOREIGN KEY (goalId) REFERENCES GoalEntity(id) ON DELETE CASCADE,
    FOREIGN KEY (milestoneId) REFERENCES MilestoneEntity(id) ON DELETE CASCADE
);

-- Focus Session queries
insertFocusSession:
INSERT OR REPLACE INTO FocusSessionEntity(id, goalId, milestoneId, plannedDurationMinutes, actualDurationSeconds, wasCompleted, xpEarned, startedAt, completedAt, createdAt, mood, ambientSound, focusTheme, sync_updated_at, is_deleted, sync_version, last_synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

updateFocusSession:
UPDATE FocusSessionEntity
SET actualDurationSeconds = ?, wasCompleted = ?, xpEarned = ?, completedAt = ?, mood = ?, ambientSound = ?, focusTheme = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE id = ?;

getFocusSessionById:
SELECT * FROM FocusSessionEntity WHERE id = ? AND is_deleted = 0;

getFocusSessionsByGoalId:
SELECT * FROM FocusSessionEntity WHERE goalId = ? AND is_deleted = 0 ORDER BY createdAt DESC;

getFocusSessionsByMilestoneId:
SELECT * FROM FocusSessionEntity WHERE milestoneId = ? AND is_deleted = 0 ORDER BY createdAt DESC;

getCompletedFocusSessions:
SELECT * FROM FocusSessionEntity WHERE wasCompleted = 1 AND is_deleted = 0 ORDER BY completedAt DESC;

getTotalFocusSeconds:
SELECT COALESCE(SUM(actualDurationSeconds), 0) FROM FocusSessionEntity WHERE wasCompleted = 1 AND is_deleted = 0;

getTotalFocusSessionCount:
SELECT COUNT(*) FROM FocusSessionEntity WHERE wasCompleted = 1 AND is_deleted = 0;

getTodayFocusSessions:
SELECT * FROM FocusSessionEntity WHERE startedAt LIKE ? || '%' AND is_deleted = 0 ORDER BY startedAt DESC;

selectAllFocusSessions:
SELECT * FROM FocusSessionEntity WHERE is_deleted = 0 ORDER BY createdAt DESC;

-- Indexes for focus sessions
CREATE INDEX IF NOT EXISTS idx_focus_goal ON FocusSessionEntity(goalId);
CREATE INDEX IF NOT EXISTS idx_focus_milestone ON FocusSessionEntity(milestoneId);
CREATE INDEX IF NOT EXISTS idx_focus_completed ON FocusSessionEntity(wasCompleted);
CREATE INDEX IF NOT EXISTS idx_focus_started ON FocusSessionEntity(startedAt);

-- ============== Sync Performance Indexes ==============
-- Composite indexes for getUnsynced* queries: WHERE (last_synced_at IS NULL OR sync_updated_at > last_synced_at) AND is_deleted = 0
-- and getDeleted* queries: WHERE is_deleted = 1

CREATE INDEX IF NOT EXISTS idx_goal_sync ON GoalEntity(is_deleted, last_synced_at);
CREATE INDEX IF NOT EXISTS idx_milestone_sync ON MilestoneEntity(is_deleted, last_synced_at);
CREATE INDEX IF NOT EXISTS idx_goal_history_sync ON GoalHistoryEntity(is_deleted, last_synced_at);
CREATE INDEX IF NOT EXISTS idx_user_progress_sync ON UserProgressEntity(is_deleted, last_synced_at);
CREATE INDEX IF NOT EXISTS idx_user_sync ON UserEntity(is_deleted, lastSyncedAt);
CREATE INDEX IF NOT EXISTS idx_habit_sync ON HabitEntity(is_deleted, last_synced_at);
CREATE INDEX IF NOT EXISTS idx_habit_checkin_sync ON HabitCheckInEntity(is_deleted, last_synced_at);
CREATE INDEX IF NOT EXISTS idx_journal_sync ON JournalEntryEntity(is_deleted, last_synced_at);
CREATE INDEX IF NOT EXISTS idx_badge_sync ON BadgeEntity(is_deleted, last_synced_at);
CREATE INDEX IF NOT EXISTS idx_challenge_sync ON ChallengeEntity(is_deleted, last_synced_at);
CREATE INDEX IF NOT EXISTS idx_goal_dependency_sync ON GoalDependencyEntity(is_deleted, last_synced_at);
CREATE INDEX IF NOT EXISTS idx_chat_session_sync ON ChatSessionEntity(is_deleted, last_synced_at);
CREATE INDEX IF NOT EXISTS idx_chat_message_sync ON ChatMessageEntity(is_deleted, last_synced_at);
CREATE INDEX IF NOT EXISTS idx_review_sync ON ReviewReportEntity(is_deleted, last_synced_at);
CREATE INDEX IF NOT EXISTS idx_reminder_sync ON ReminderEntity(is_deleted, last_synced_at);
CREATE INDEX IF NOT EXISTS idx_custom_coach_sync ON CustomCoachEntity(is_deleted, last_synced_at);
CREATE INDEX IF NOT EXISTS idx_coach_group_sync ON CoachGroupEntity(is_deleted, last_synced_at);
CREATE INDEX IF NOT EXISTS idx_coach_group_member_sync ON CoachGroupMemberEntity(is_deleted, last_synced_at);
CREATE INDEX IF NOT EXISTS idx_focus_session_sync ON FocusSessionEntity(is_deleted, last_synced_at);

-- Sync pull ordering indexes
CREATE INDEX IF NOT EXISTS idx_goals_sync_updated ON GoalEntity(sync_updated_at);
CREATE INDEX IF NOT EXISTS idx_milestones_sync_updated ON MilestoneEntity(sync_updated_at);
CREATE INDEX IF NOT EXISTS idx_habits_sync_updated ON HabitEntity(sync_updated_at);
CREATE INDEX IF NOT EXISTS idx_journal_sync_updated ON JournalEntryEntity(sync_updated_at);

-- Composite index for habit streak calculations
CREATE INDEX IF NOT EXISTS idx_checkins_habit_date ON HabitCheckInEntity(habitId, date);

-- is_deleted filter (used in nearly every SELECT)
CREATE INDEX IF NOT EXISTS idx_goals_deleted ON GoalEntity(is_deleted);
CREATE INDEX IF NOT EXISTS idx_milestones_deleted ON MilestoneEntity(is_deleted);
CREATE INDEX IF NOT EXISTS idx_habits_deleted ON HabitEntity(is_deleted);
CREATE INDEX IF NOT EXISTS idx_journal_deleted ON JournalEntryEntity(is_deleted);

-- Focus session date range queries
CREATE INDEX IF NOT EXISTS idx_focus_date ON FocusSessionEntity(startedAt, wasCompleted);

-- ============== Retrospective Queries ==============

-- Get all habits with their check-in status for a specific date
getHabitCheckInsWithHabitForDate:
SELECT h.id, h.title, h.description, h.category, h.frequency, h.targetCount,
       h.currentStreak, h.longestStreak, h.totalCompletions, h.lastCompletedDate,
       h.linkedGoalId, h.correlationScore, h.isActive, h.createdAt, h.reminderTime,
       c.completed, c.notes AS checkInNotes
FROM HabitEntity h
LEFT JOIN HabitCheckInEntity c ON h.id = c.habitId AND c.date = ?
WHERE h.isActive = 1;

-- Get focus sessions for a specific date (using date prefix match on startedAt)
getFocusSessionsByDate:
SELECT * FROM FocusSessionEntity WHERE startedAt LIKE ? || '%' AND is_deleted = 0 ORDER BY startedAt ASC;

-- Get goal changes on a specific date with goal title
getGoalChangesOnDate:
SELECT gh.id, gh.goalId, gh.field AS fieldName, gh.oldValue, gh.newValue, gh.changedAt, g.title AS goalTitle
FROM GoalHistoryEntity gh
LEFT JOIN GoalEntity g ON gh.goalId = g.id
WHERE gh.changedAt LIKE ? || '%'
ORDER BY gh.changedAt DESC;

-- Get badges earned on a specific date
getBadgesEarnedOnDate:
SELECT * FROM BadgeEntity WHERE earnedAt LIKE ? || '%' ORDER BY earnedAt DESC;

-- Get goals that existed on a date (created before or on that date, not archived)
getGoalsExistingOnDate:
SELECT * FROM GoalEntity WHERE createdAt <= ? AND isArchived = 0 AND is_deleted = 0 ORDER BY createdAt DESC;

-- Get distinct dates with any activity (for calendar dot indicators)
getDatesWithActivity:
SELECT DISTINCT date FROM (
    SELECT date FROM HabitCheckInEntity WHERE date >= ? AND date <= ?
    UNION
    SELECT date FROM JournalEntryEntity WHERE date >= ? AND date <= ?
    UNION
    SELECT SUBSTR(startedAt, 1, 10) AS date FROM FocusSessionEntity WHERE SUBSTR(startedAt, 1, 10) >= ? AND SUBSTR(startedAt, 1, 10) <= ?
    UNION
    SELECT SUBSTR(changedAt, 1, 10) AS date FROM GoalHistoryEntity WHERE SUBSTR(changedAt, 1, 10) >= ? AND SUBSTR(changedAt, 1, 10) <= ?
    UNION
    SELECT SUBSTR(earnedAt, 1, 10) AS date FROM BadgeEntity WHERE SUBSTR(earnedAt, 1, 10) >= ? AND SUBSTR(earnedAt, 1, 10) <= ?
);

-- ============== Sync Queries ==============

-- Goal sync queries
getUnsyncedGoals:
SELECT * FROM GoalEntity WHERE (last_synced_at IS NULL OR sync_updated_at > last_synced_at) AND is_deleted = 0 AND id != 'getting_started_goal';

getDeletedGoals:
SELECT * FROM GoalEntity WHERE is_deleted = 1 AND id != 'getting_started_goal';

markGoalSynced:
UPDATE GoalEntity SET last_synced_at = ? WHERE id = ?;

softDeleteGoal:
UPDATE GoalEntity SET is_deleted = 1, sync_updated_at = ? WHERE id = ?;

purgeDeletedGoals:
DELETE FROM GoalEntity WHERE is_deleted = 1 AND last_synced_at IS NOT NULL;

-- Milestone sync queries
getUnsyncedMilestones:
SELECT * FROM MilestoneEntity WHERE (last_synced_at IS NULL OR sync_updated_at > last_synced_at) AND is_deleted = 0 AND id NOT LIKE 'gs_milestone_%';

getDeletedMilestones:
SELECT * FROM MilestoneEntity WHERE is_deleted = 1 AND id NOT LIKE 'gs_milestone_%';

markMilestoneSynced:
