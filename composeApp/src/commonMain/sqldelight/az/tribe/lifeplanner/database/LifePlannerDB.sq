-- Coach Persona Override Table for customizing built-in coach behavior
CREATE TABLE IF NOT EXISTS CoachPersonaOverrideEntity (
    coachId TEXT PRIMARY KEY NOT NULL,
    userPersona TEXT NOT NULL DEFAULT '',
    updatedAt TEXT NOT NULL,
    sync_updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    sync_version INTEGER NOT NULL DEFAULT 0,
    last_synced_at TEXT
);

getCoachPersonaOverride:
SELECT * FROM CoachPersonaOverrideEntity WHERE coachId = ? AND is_deleted = 0;

upsertCoachPersonaOverride:
INSERT OR REPLACE INTO CoachPersonaOverrideEntity(coachId, userPersona, updatedAt, sync_updated_at, is_deleted, sync_version, last_synced_at)
VALUES (?, ?, ?, ?, 0, 0, NULL);

deleteCoachPersonaOverride:
UPDATE CoachPersonaOverrideEntity SET is_deleted = 1, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now') WHERE coachId = ?;

-- CoachPersonaOverride sync queries
getUnsyncedCoachPersonaOverrides:
SELECT * FROM CoachPersonaOverrideEntity WHERE (last_synced_at IS NULL OR sync_updated_at > last_synced_at) AND is_deleted = 0;

getDeletedCoachPersonaOverrides:
SELECT * FROM CoachPersonaOverrideEntity WHERE is_deleted = 1;

markCoachPersonaOverrideSynced:
UPDATE CoachPersonaOverrideEntity SET last_synced_at = ? WHERE coachId = ?;

purgeDeletedCoachPersonaOverrides:
DELETE FROM CoachPersonaOverrideEntity WHERE is_deleted = 1 AND last_synced_at IS NOT NULL;

upsertCoachPersonaOverrideFromSync:
INSERT OR REPLACE INTO CoachPersonaOverrideEntity(coachId, userPersona, updatedAt, sync_updated_at, is_deleted, sync_version, last_synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?);

-- ===== Beginner Objectives =====
CREATE TABLE IF NOT EXISTS BeginnerObjectiveEntity (
    id TEXT PRIMARY KEY NOT NULL,
    objectiveType TEXT NOT NULL,
    isCompleted INTEGER NOT NULL DEFAULT 0,
    completedAt TEXT,
    xpAwarded INTEGER NOT NULL DEFAULT 0,
    createdAt TEXT NOT NULL,
    sync_updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    sync_version INTEGER NOT NULL DEFAULT 0,
    last_synced_at TEXT
);

insertBeginnerObjective:
INSERT OR REPLACE INTO BeginnerObjectiveEntity(id, objectiveType, isCompleted, completedAt, xpAwarded, createdAt, sync_updated_at, is_deleted, sync_version, last_synced_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getAllBeginnerObjectives:
SELECT * FROM BeginnerObjectiveEntity WHERE is_deleted = 0;

getBeginnerObjectiveByType:
SELECT * FROM BeginnerObjectiveEntity WHERE objectiveType = ? AND is_deleted = 0 LIMIT 1;

deduplicateBeginnerObjectives:
DELETE FROM BeginnerObjectiveEntity
WHERE id NOT IN (
    SELECT MIN(id) FROM BeginnerObjectiveEntity GROUP BY objectiveType
);

getCompletedBeginnerObjectivesCount:
SELECT COUNT(*) FROM BeginnerObjectiveEntity WHERE isCompleted = 1 AND is_deleted = 0;

completeBeginnerObjective:
UPDATE BeginnerObjectiveEntity
SET isCompleted = 1, completedAt = ?, xpAwarded = ?, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE objectiveType = ? AND isCompleted = 0;

uncompleteBeginnerObjective:
UPDATE BeginnerObjectiveEntity
SET isCompleted = 0, completedAt = NULL, xpAwarded = 0, sync_updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now')
WHERE objectiveType = ? AND isCompleted = 1;

deleteAllBeginnerObjectives:
DELETE FROM BeginnerObjectiveEntity;

-- Beginner Objectives sync queries
getUnsyncedBeginnerObjectives:
SELECT * FROM BeginnerObjectiveEntity WHERE (last_synced_at IS NULL OR sync_updated_at > last_synced_at) AND is_deleted = 0;

getDeletedBeginnerObjectives:
SELECT * FROM BeginnerObjectiveEntity WHERE is_deleted = 1;

