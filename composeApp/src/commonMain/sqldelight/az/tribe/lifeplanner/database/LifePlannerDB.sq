softDeleteMilestone:
UPDATE MilestoneEntity SET is_deleted = 1, sync_updated_at = ? WHERE id = ?;

softDeleteMilestonesByGoalId:
UPDATE MilestoneEntity SET is_deleted = 1, sync_updated_at = ? WHERE goalId = ? AND is_deleted = 0;

purgeDeletedMilestones:
DELETE FROM MilestoneEntity WHERE is_deleted = 1 AND last_synced_at IS NOT NULL;

